{
  "manifest_version": 3,
  "name": "新格 · 新标签页",
  "version": "1.0.0",
  "description": "新格 NovaTab —— 玻璃质感的自定义新标签页：时钟、天气、多引擎搜索、快捷方式与文件夹、主题与壁纸。",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://www.google.com/s2/*",
    "https://api.bigdatacloud.net/*",
    "https://wallhaven.cc/*",
    "https://*.wallhaven.cc/*"
  ]
}
